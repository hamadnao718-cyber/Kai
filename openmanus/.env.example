# OpenManus MCP Server — environment variable template
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# These variables are read by mcp_server.py at startup to auto-generate
# config/config.toml when the file does not already exist.

# ── LLM credentials ────────────────────────────────────────────────────────
OPENMANUS_API_KEY=sk-...
OPENMANUS_API_BASE_URL=https://api.openai.com/v1
OPENMANUS_MODEL=gpt-4o

# ── Server binding ──────────────────────────────────────────────────────────
OPENMANUS_HOST=0.0.0.0
OPENMANUS_PORT=8765
